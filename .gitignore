# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
/target
/fuzz/target
/tests/traefik_integration/target
/tests/traefik_integration/Cargo.lock
**/*.rs.bk
*.pdb

# -----------------------------------------------------------------------------
# Fuzz: keep committed seeds; ignore libFuzzer's grown corpus + crash artifacts
# -----------------------------------------------------------------------------
/fuzz/corpus/**/*
!/fuzz/corpus/*/
!/fuzz/corpus/*/seed-*
/fuzz/artifacts

# -----------------------------------------------------------------------------
# Coverage / profiling
# -----------------------------------------------------------------------------
*.profraw
*.profdata
lcov.info
cobertura.xml
tarpaulin-report.html
flamegraph.svg
perf.data
perf.data.old

# -----------------------------------------------------------------------------
# Secrets / local config (defense in depth — none tracked today)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
.envrc.local
.direnv/
*.key
*.pem
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
.vs/
*.iml
*.swp
*.swo
*~
.nvimlog

# -----------------------------------------------------------------------------
# OS noise
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
