{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "relay": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": { "$ref": "#/definitions/image" },
        "config": {
          "type": "object",
          "required": ["sources", "subscribers"],
          "properties": {
            "sources": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": { "enum": ["stdin", "log_tail"] },
                  "path": { "type": "string", "minLength": 1 },
                  "from_beginning": { "type": "boolean" }
                },
                "allOf": [
                  {
                    "if": { "properties": { "type": { "const": "log_tail" } } },
                    "then": { "required": ["path"] }
                  }
                ]
              }
            },
            "subscribers": {
              "type": "array",
              "items": { "$ref": "#/definitions/subscriber" }
            },
            "relay": {
              "type": "object",
              "properties": {
                "subscriber_queue": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },
    "wasmAsset": {
      "type": "object",
      "properties": {
        "image": { "$ref": "#/definitions/image" }
      }
    }
  },
  "definitions": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": {
          "type": "string",
          "pattern": "^$|^sha256:[a-f0-9]{64}$"
        },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "subscriber": {
      "type": "object",
      "required": ["id", "url"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-zA-Z0-9_.-]+$" },
        "url": { "type": "string", "pattern": "^https?://.+" },
        "secret_env": { "type": "string", "minLength": 1 },
        "secret_file": { "type": "string", "minLength": 1 },
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "enabled": { "type": "boolean" },
        "filter": { "type": "object" },
        "retry": {
          "type": "object",
          "properties": {
            "max_attempts": { "type": "integer", "minimum": 1 },
            "base_delay_ms": { "type": "integer", "minimum": 0 },
            "max_delay_ms": { "type": "integer", "minimum": 0 }
          }
        }
      },
      "oneOf": [
        { "required": ["secret_env"], "not": { "required": ["secret_file"] } },
        { "required": ["secret_file"], "not": { "required": ["secret_env"] } }
      ]
    }
  }
}
